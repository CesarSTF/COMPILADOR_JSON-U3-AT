// Fase 1: Análisis Léxico y Sintáctico
// Símbolo Inicial (INICIO)
inicio: objeto

// Símbolos No Terminales (Reglas de Producción)
objeto: "{" miembros "}" 
      | "{" "}"

miembros: par ("," par)*

par: T_STRING ":" valor

valor: T_STRING 
     | T_NUMERO 
     | T_BOOLEANO 
     | objeto

// Símbolos Terminales (Tokens y Expresiones Regulares)
T_STRING: /"[^"]*"/
T_NUMERO: /[0-9]+/
T_BOOLEANO: "true" | "false"

// Reglas de ignorado (espacios, saltos de línea)
%import common.WS
%ignore WS
